# SPAWN Clinical — Environment Variables
# Copy to `.env` locally, and set these in the Vercel dashboard for production.
# NOTE: The values below were previously hardcoded in PHP and should be ROTATED.

# Anthropic Claude API (chatbot + spawn generation)
ANTHROPIC_API_KEY=

# HubSpot private-app token (lead capture)
HUBSPOT_TOKEN=

# Database — during migration this becomes the Neon Postgres connection string.
# Legacy GoDaddy MySQL values (for reference during cutover only):
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=

# After Neon setup, Vercel injects this automatically:
# DATABASE_URL=postgres://...
