# SPAWN Clinical — Environment Variables
# Copy to `.env` for local dev, and set these in the Vercel dashboard
# (Project → Settings → Environment Variables) for production.
#
# ⚠  The Anthropic + HubSpot values were previously hardcoded in PHP on GoDaddy.
#     ROTATE them before/after go-live.

# ── Anthropic Claude (chatbot + spawn generation) ──
ANTHROPIC_API_KEY=

# ── HubSpot private-app token (lead capture) ──
HUBSPOT_TOKEN=

# ── Neon Postgres ──
# Auto-injected by Vercel when you connect a Neon database (Storage → Neon).
# For local dev, paste your Neon connection string here.
DATABASE_URL=

# ── Email notifications for chatbot "ideas" (optional) ──
# Uses Resend (https://resend.com). If unset, idea emails are skipped silently.
RESEND_API_KEY=
IDEA_NOTIFY_TO=info@spawnclinical.com
IDEA_NOTIFY_FROM=SPAWN Dusty <noreply@spawnclinical.com>
